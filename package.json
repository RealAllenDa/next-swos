{
  "name": "next-swos",
  "version": "0.0.1",
  "description": "Shanghai Weather Observation System",
  "productName": "SWoS",
  "author": "RealAllenDa (HomeNetwork)",
  "private": true,
  "scripts": {
    "dev": "quasar dev",
    "build": "quasar build",
    "build:pwa": "quasar build -m pwa",
    "lint": "eslint --ext .js,.ts,.vue ./",
    "typecheck": "vue-tsc --noEmit",
    "format": "prettier --write \"**/*.{js,ts,vue,scss,html,md,json}\" --ignore-path .gitignore",
    "test": "npm run lint && npm run typecheck"
  },
  "dependencies": {
    "@quasar/extras": "^2.0.2",
    "@turf/turf": "^6.5.0",
    "date-fns": "^2.29.1",
    "html2canvas": "^1.4.1",
    "maplibre-gl": "^3.2.1",
    "nouislider": "^15.7.1",
    "pinia": "^3.0.4",
    "quasar": "^2.21.2",
    "vue": "^3.5.39",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@quasar/app-vite": "^3.0.1",
    "@types/node": "^24.0.0",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "autoprefixer": "^10.4.2",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^8.10.2",
    "eslint-plugin-vue": "^9.33.0",
    "prettier": "^2.8.8",
    "typescript": "^5.9.3",
    "vue-tsc": "^2.2.12"
  },
  "engines": {
    "node": "^30 || ^28 || ^26 || ^24 || ^22.22.0",
    "npm": ">= 10",
    "yarn": ">= 1.21.1"
  }
}
